{
  "name": "volt-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Volt — a tiny no-build, signals-based UI library, and create-volt, its create-react-app-style scaffolder.",
  "type": "module",
  "workspaces": [
    "packages/*",
    "example",
    "site"
  ],
  "scripts": {
    "example": "node example/server.js",
    "create-volt": "node packages/create-volt/index.js",
    "release": "node scripts/release.mjs",
    "update-deps": "node scripts/update-deps.mjs",
    "test": "node --test",
    "test:browser": "node scripts/browser-test.mjs",
    "smoke": "node scripts/smoke.mjs"
  },
  "license": "MIT"
}
