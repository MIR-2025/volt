# nginx for voltjs.com — proxy /api/ (+ the Stripe webhook) to the volt-ai-gateway on
# 127.0.0.1:8787, and everything else to the marketing site (volt-site) on 127.0.0.1:26628.
#
# You already have a voltjs.com server{} block (the site is live on HTTPS). You only need to
# ADD the two gateway `location` blocks below into that existing block — above `location /`.
# Then:  sudo nginx -t  &&  sudo systemctl reload nginx
#
# CRITICAL: no trailing slash on the gateway proxy_pass. The gateway's routes include the
# /api prefix (app.post("/api/register"), "/api/ai", …), so `proxy_pass …:8787;` must pass
# the full URI through. A trailing slash (`…:8787/`) would strip /api/ → 404.

server {
    server_name voltjs.com www.voltjs.com;

    # ---- hosted-AI gateway: token registration + AI proxy + credits ----
    location /api/ {
        proxy_pass http://127.0.0.1:8787;          # NO trailing slash — keep the /api prefix
        proxy_http_version 1.1;
        proxy_set_header Host               $host;
        proxy_set_header X-Real-IP          $remote_addr;
        proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;  # gateway rate-limits on this
        proxy_set_header X-Forwarded-Proto  $scheme;
        proxy_buffering off;                        # stream AI responses instead of buffering
        proxy_read_timeout 300s;                    # long generations
    }

    # ---- Stripe webhook: signature is verified on the RAW body, which nginx forwards as-is ----
    location = /webhooks/stripe {
        proxy_pass http://127.0.0.1:8787;
        proxy_set_header Host            $host;
        proxy_set_header X-Real-IP       $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        # (Stripe payloads are tiny; the default client_max_body_size is fine.)
    }

    # ---- everything else: the marketing site (volt-site) ----
    location / {
        proxy_pass http://127.0.0.1:26628;
        proxy_http_version 1.1;
        proxy_set_header Host               $host;
        proxy_set_header X-Real-IP          $remote_addr;
        proxy_set_header X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto  $scheme;
    }

    # TLS is managed by certbot (these lines are usually added by `certbot --nginx`):
    listen 443 ssl;
    # ssl_certificate     /etc/letsencrypt/live/voltjs.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/voltjs.com/privkey.pem;
    # include             /etc/letsencrypt/options-ssl-nginx.conf;
}

# HTTP → HTTPS
server {
    listen 80;
    server_name voltjs.com www.voltjs.com;
    return 301 https://$host$request_uri;
}

# NOTE: /admin/* on the gateway is intentionally NOT proxied — it's admin-token-gated and
# should stay off the public web. Only /api/ and /webhooks/stripe are exposed.
