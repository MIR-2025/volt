# volt-ai-gateway — copy to .env and fill in. Keep this file OUT of git.

# The capped Anthropic Workspace key. Create a dedicated Workspace in the Anthropic
# console with its own spend limit, and use THAT key here — never your root key.
# This is the only place the key ever lives.
ANTHROPIC_API_KEY=

# Bearer for /admin/* (issuing + revoking per-app tokens). Generate a long random
# string, e.g.  openssl rand -base64 32
ADMIN_TOKEN=change-me-long-random

# Hard ceilings (tokens/day). Global is the runaway backstop across all apps;
# per-app is the default cap stamped on each token you issue.
GLOBAL_DAILY_TOKEN_CAP=5000000
DEFAULT_APP_DAILY_CAP=100000

# Model + per-request clamp.
AI_MODEL=claude-haiku-4-5
AI_MAX_TOKENS=1024

# Pay-as-you-go: usage beyond an app's free daily cap is billed against prepaid
# credits at MARKUP x the Anthropic cost. PRICING_JSON overrides the per-model
# $/Mtok defaults (verify these against current Anthropic pricing!).
AI_MARKUP=8
# PRICING_JSON={"claude-haiku-4-5":{"in":1,"out":5}}

# Stripe (self-service credit purchases). Without these, free tier + BYO still
# work; only buying credits is disabled.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# STRIPE_ACCOUNT=          # only for org-level API keys

PORT=8787
DATA_DIR=./data
