{
  "name": "volt-guestbook",
  "version": "0.1.0",
  "private": true,
  "description": "Live guestbook — a real Volt app: magic-link auth, Socket.io real-time, pluggable MongoDB/MySQL/Postgres storage (with an in-memory dev fallback).",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "pm2": "npx --yes pm2 start ecosystem.config.cjs",
    "pm2:restart": "npx --yes pm2 restart ecosystem.config.cjs",
    "pm2:stop": "npx --yes pm2 delete ecosystem.config.cjs",
    "pm2:logs": "npx --yes pm2 logs"
  },
  "dependencies": {
    "express": "^4.22.2",
    "socket.io": "^4.8.3"
  },
  "optionalDependencies": {
    "mongodb": "^6.21.0",
    "mysql2": "^3.22.6",
    "pg": "^8.22.0"
  }
}
