# volt-image-host — shared DigitalOcean Spaces image service
PORT=26707

# ── DO Spaces (S3-compatible) ────────────────────────────────────────────────
# Create a bucket + "Spaces access keys" in the DO console, and (recommended)
# enable the bucket's CDN. One bucket serves every site; keys are namespaced by
# a sites/<siteId>/ prefix.
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_REGION=us-east-1
SPACES_BUCKET=volt-media
SPACES_CDN=https://volt-media.nyc3.cdn.digitaloceanspaces.com
SPACES_KEY=
SPACES_SECRET=

# ── limits / optimization ────────────────────────────────────────────────────
SITE_QUOTA_BYTES=1073741824      # 1 GB allocated per site (real use ~200 MB → safe overcommit)
MAX_UPLOAD_BYTES=26214400        # 25 MB per file (kills video dumps)
IMAGE_FORMAT=webp                # webp (universal) or avif (smaller, ~95% browsers)
IMAGE_QUALITY=80
IMAGE_MAX_DIM=2400               # cap the longest edge

# ── auth ─────────────────────────────────────────────────────────────────────
# A shared admin token (the platform), and/or per-site bearer keys.
ADMIN_TOKEN=
SITE_KEYS=                       # e.g. acme-blog:key_abc,jane-co:key_def
