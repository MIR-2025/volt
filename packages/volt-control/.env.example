# volt-control — hosting control plane
PORT=26709
BASE_URL=https://host.voltjs.com          # where magic links point

# State + the trees the other services read/write
DATA_DIR=/srv/volt-control/data           # JSON store (accounts/sites/domains)
SITES_ROOT=/srv/volt-sites                # provisioned static dirs (volt-static-host reads)
PROJECTS_ROOT=/srv/volt-projects          # each site's Volt source project
DOMAINS_MAP=/srv/volt-domains.json        # verified custom domains (volt-static-host reads)
TENANT_DOMAIN=vsites.app                  # tenant default URLs: <siteId>.vsites.app
PUBLISH_WORKER=../volt-publish/worker.js  # defaults next to this package

# Storage metering (reads volt-image-host /usage)
IMAGE_HOST_URL=http://127.0.0.1:26707
IMAGE_HOST_TOKEN=

# Billing — leave STRIPE_SECRET_KEY unset for dev/self-host (upgrade is a no-op flip)
STRIPE_SECRET_KEY=
