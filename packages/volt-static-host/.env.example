# volt-static-host — shared multi-tenant static origin
PORT=26708

# Where each site's compiled static output lives: SITES_ROOT/<siteId>/
SITES_ROOT=/srv/volt-sites

# Platform base domain — <siteId>.<BASE_DOMAIN> routes to that site.
BASE_DOMAIN=volthost.com

# Optional custom-domain → siteId map (JSON: { "www.acme.com": "acme-blog" }).
# Reload without a restart:  kill -HUP <pid>
DOMAINS_MAP=/srv/volt-domains.json

# Cache-Control (this is the CDN origin; let the CDN do the heavy lifting).
HTML_CACHE=public, max-age=60, must-revalidate
ASSET_CACHE=public, max-age=31536000, immutable
OTHER_CACHE=public, max-age=3600
