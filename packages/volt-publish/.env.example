# volt-publish — build/publish worker
# (config is mostly CLI flags; these env vars enable the Spaces image push)

# Where the static host reads sites from — SITES_ROOT/<siteId>/ is written here.
SITES_ROOT=/srv/volt-sites

# Port used to boot a project during a build (ephemeral; pick anything free).
BOOT_PORT=28080

# Push images to volt-image-host (→ Spaces) instead of bundling them locally.
# Leave unset to keep images in the static bundle.
IMAGE_HOST_URL=http://127.0.0.1:26707
IMAGE_HOST_TOKEN=
